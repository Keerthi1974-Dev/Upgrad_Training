@model List<WebApplication6.Models.Movie>

<div class="container mt-5">
    <h2 class="text-center mb-3">Movie List</h2>

    <div class="text-center mb-3">
        <a href="/Movie/Create" class="btn btn-primary">Add Movie</a>
    </div>

    <table class="table table-bordered table-striped table-hover text-center">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Genre</th>
                <th>Release Date</th>
                <th>Price</th>
                <th>Rating</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Genre</td>
                    <td>@item.ReleaseDate.ToShortDateString()</td>
                    <td>@item.Price</td>
                    <td>@item.Rating</td>
                    <td>
                        <a href="/Movie/Edit/@item.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/Movie/Delete/@item.Id" class="btn btn-danger btn-sm">Delete</a>
                        <a href="/Movie/Details/@item.Id" class="btn btn-info btn-sm">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>